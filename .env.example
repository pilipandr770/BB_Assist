# ============================================================
# Bug Bounty Assistant — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# OPTIONAL — Free tier APIs (tool works without these,
# but results are better with them)
# ------------------------------------------------------------

# VirusTotal — 500 queries/day free
# Sign up: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# URLScan.io — ~100 scans/day free
# Sign up: https://urlscan.io/user/signup
URLSCAN_API_KEY=

# AlienVault OTX — unlimited free
# Sign up: https://otx.alienvault.com/
OTX_API_KEY=

# IPInfo.io — 50,000 requests/month free
# Sign up: https://ipinfo.io/signup
IPINFO_TOKEN=

# GitHub — for dorking exposed secrets in public repos (HIGHLY RECOMMENDED)
# Create token: https://github.com/settings/tokens/new → scope: read:public_repo
# Without this, GitHub dorking phase is skipped automatically
GITHUB_TOKEN=

# ------------------------------------------------------------
# INTERNAL — don't change unless you know what you're doing
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379
WORKSPACE_DIR=/app/workspace
LOG_LEVEL=INFO
