# ============================================================
# Bug Bounty Assistant — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ------------------------------------------------------------
# REQUIRED
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic model routing (task-specific)
# Defaults are optimized for cost/performance balance:
# - scope parsing: Haiku
# - report generation: Opus
# - most other tasks: Sonnet
ANTHROPIC_MODEL_SCOPE=claude-haiku-4-5
ANTHROPIC_MODEL_PLAN=claude-sonnet-4-6
ANTHROPIC_MODEL_FILTER=claude-sonnet-4-6
ANTHROPIC_MODEL_POC=claude-sonnet-4-6
ANTHROPIC_MODEL_REPORT=claude-opus-4-7
ANTHROPIC_MODEL_REWRITE=claude-sonnet-4-6

# Fallback chain used when the primary model fails.
ANTHROPIC_MODEL_FALLBACKS=claude-sonnet-4-6,claude-haiku-4-5

# Estimated pricing (USD per 1M tokens) used for telemetry in UI.
ANTHROPIC_COST_OPUS_INPUT_PER_MTOK=15.0
ANTHROPIC_COST_OPUS_OUTPUT_PER_MTOK=75.0
ANTHROPIC_COST_SONNET_INPUT_PER_MTOK=3.0
ANTHROPIC_COST_SONNET_OUTPUT_PER_MTOK=15.0
ANTHROPIC_COST_HAIKU_INPUT_PER_MTOK=0.8
ANTHROPIC_COST_HAIKU_OUTPUT_PER_MTOK=4.0

# ------------------------------------------------------------
# OPTIONAL — Free tier APIs (tool works without these,
# but results are better with them)
# ------------------------------------------------------------

# VirusTotal — 500 queries/day free
# Sign up: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# URLScan.io — ~100 scans/day free
# Sign up: https://urlscan.io/user/signup
URLSCAN_API_KEY=

# AlienVault OTX — unlimited free
# Sign up: https://otx.alienvault.com/
OTX_API_KEY=

# IPInfo.io — 50,000 requests/month free
# Sign up: https://ipinfo.io/signup
IPINFO_TOKEN=

# GitHub — for dorking exposed secrets in public repos (HIGHLY RECOMMENDED)
# Create token: https://github.com/settings/tokens/new → scope: read:public_repo
# Without this, GitHub dorking phase is skipped automatically
GITHUB_TOKEN=

# HackerOne credentials (optional — enables auto-submit and program discovery)
# Your H1 username (e.g. "andrii-it")
H1_USERNAME=
# Generate API token at: https://hackerone.com/settings/api_token/edit
H1_API_TOKEN=

# Telegram notifications (optional — leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: remote curated CSV with columns
# product,version_regex,cve,severity,title,reference
# If configured, backend refreshes local CVE DB on startup and every
# CVE_CSV_REFRESH_HOURS hours.
# Option A: your own maintained CSV URL:
# CVE_CSV_REMOTE_URL=https://example.com/cve_service_versions.csv
# Option B: raw CVEProject source (backend auto-converts JSON to CSV):
# CVE_CSV_REMOTE_URL=https://github.com/CVEProject/cvelistV5
CVE_CSV_REMOTE_URL=
CVE_CSV_REFRESH_HOURS=24
# For CVEProject/cvelistV5 mode: convert only recent years and cap rows.
CVE_CVELIST_YEARS_BACK=8
CVE_CVELIST_MAX_ROWS=20000

# ------------------------------------------------------------
# INTERNAL — don't change unless you know what you're doing
# ------------------------------------------------------------
REDIS_URL=redis://redis:6379
WORKSPACE_DIR=/app/workspace
LOG_LEVEL=INFO
